# ============================================================================
# Placement Preparation Tracker — backend environment template.
# Copy to backend/.env (or repo-root .env for docker-compose) and fill values.
# NEVER commit the filled .env.
# ============================================================================

# --- Database ---
# Local docker-compose default:
#   postgresql+asyncpg://placement:placement@db:5432/placement_tracker
DATABASE_URL=postgresql+asyncpg://placement:placement@db:5432/placement_tracker

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-please-32-chars-min
JWT_REFRESH_SECRET_KEY=change-me-also-please-32-chars-min

# --- Google OAuth2 ---
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Authorized redirect URI in Google Console must equal:  ${BACKEND_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (resume PDF storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- App URLs (no trailing slash) ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
